# Runtime
APP_NAME=SiteFormo AI Sales Platform
APP_ENV=production
ENV=production
LOG_LEVEL=info
PUBLIC_BASE_URL=http://127.0.0.1:8000
DATABASE_URL=sqlite:///./siteformo_local.db

# Admin/security
ADMIN_API_KEY=change-me-long-random-secret
APPROVAL_SECRET=change-me-long-random-secret
ASSET_SIGNING_SECRET=change-me-long-random-secret
TURNSTILE_SECRET_KEY=
ALLOW_MANUAL_DECISION_WITHOUT_TOKEN=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_HOUR=60
FREE_ATTEMPT_LIMIT=1
BYPASS_LIMIT_EMAILS=
PAYMENT_APPROVAL_BYPASS_EMAILS=owner@example.com

# Owner notifications
OWNER_EMAIL=owner@example.com
OWNER_TELEGRAM_CHAT_ID=
ENABLE_OWNER_NOTIFICATIONS=true
DIVI_EXPORT_EMAIL=

# OpenAI / AI
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5.1-mini
OPENAI_TIMEOUT_SECONDS=25
OPENAI_MAX_RETRIES=2
AI_MEMORY_MAX_HISTORY=12
AI_MEMORY_TTL_SECONDS=86400
AI_STATE_TTL_SECONDS=86400
MAX_USER_MESSAGE_CHARS=3000
ENABLE_LEAD_EXTRACTION=true
ENABLE_DB_LEADS=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_CONTACT_LABEL=

# WhatsApp / Messenger
WHATSAPP_PROVIDER=twilio
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_PUBLIC_NUMBER=
WHATSAPP_CONTACT_NUMBER=
WHATSAPP_CONTACT_LABEL=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TWILIO_ACCOUNT_SID=
WHATSAPP_TWILIO_AUTH_TOKEN=
WHATSAPP_TWILIO_NUMBER=
MESSENGER_CONTACT_URL=
MESSENGER_CONTACT_LABEL=

# Email / SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Demo / links / follow-ups
MAIN_SITE_BASE_URL=https://siteformo.com
MAIN_SITE_CONTINUE_PATH=/continue
MAIN_SITE_CHECKOUT_PATH=/checkout
DEMO_TTL_MINUTES=60
DEMO_RETENTION_HOURS=72
DEMO_STORAGE_DIR=./demo_storage
DEMO_PROTECTION_ENABLED=true
DEMO_READY_FOLLOWUP_DELAY_MINUTES=30
DEMO_CTA_FOLLOWUP_DELAY_MINUTES=180
CHECKOUT_FOLLOWUP_DELAY_MINUTES=1440
MAX_FOLLOWUP_COUNT=3

# Queue / Redis / Supabase / storage
QUEUE_BACKEND=inline
QUEUE_POLL_SECONDS=5
QUEUE_VISIBILITY_TIMEOUT_SECONDS=60
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
STORAGE_BACKEND=auto
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=
S3_BUCKET=
POSTGRES_URL=
POSTGRESQL_URL=
SUPABASE_DB_URL=

# Telemetry
SENTRY_DSN=
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com
