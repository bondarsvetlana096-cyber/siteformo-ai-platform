# SiteFormo AI Sales Platform
# Copy to .env for local run or set these in Railway Variables

APP_NAME=SiteFormo AI Sales Platform
PUBLIC_BASE_URL=https://your-backend.up.railway.app

# Leave empty locally to use SQLite.
# In Railway Postgres paste the full DATABASE_URL.
DATABASE_URL=

APPROVAL_SECRET=change-me-super-secret-string
OWNER_EMAIL=bondarsvetlana096@gmail.com
ALLOW_MANUAL_DECISION_WITHOUT_TOKEN=true
PAYMENT_APPROVAL_BYPASS_EMAILS=bondarsvetlana096@gmail.com

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# WhatsApp
# Use twilio for Twilio Sandbox, meta for Meta WhatsApp Cloud API
WHATSAPP_PROVIDER=twilio
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_PUBLIC_NUMBER=whatsapp:+14155238886

# Meta Cloud API only
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=

# Twilio only (not required for webhook auto-reply, optional for future outbound sends)
WHATSAPP_TWILIO_ACCOUNT_SID=
WHATSAPP_TWILIO_AUTH_TOKEN=
WHATSAPP_TWILIO_NUMBER=whatsapp:+14155238886

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=bondarsvetlana096@gmail.com
DIVI_EXPORT_EMAIL=bondarsvetlana096@gmail.com
