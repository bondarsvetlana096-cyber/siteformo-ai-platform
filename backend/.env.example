# =========================
# SiteFormo AI Sales Platform
# Backend environment config
# =========================

# APP
APP_NAME=SiteFormo AI Sales Platform
PUBLIC_BASE_URL=https://your-domain.railway.app

# DATABASE
# Leave this empty to use local SQLite automatically.
# For production, set Railway Postgres or Supabase Postgres.
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# SECURITY
APPROVAL_SECRET=change-me-super-secret-string

# OWNER / NOTIFICATIONS
OWNER_EMAIL=owner@example.com

# FEATURE FLAGS
ALLOW_MANUAL_DECISION_WITHOUT_TOKEN=false
PAYMENT_APPROVAL_BYPASS_EMAILS=
TELEGRAM_BOT_USERNAME=
WHATSAPP_PUBLIC_NUMBER=

# OPENAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.1-mini

# TELEGRAM
TELEGRAM_BOT_TOKEN=

# WHATSAPP
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# EMAIL / EXPORT
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
DIVI_EXPORT_EMAIL=
